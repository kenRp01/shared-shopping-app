{
  "name": "shareshopi",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/public-pages.spec.ts tests/e2e/production-smoke.spec.ts --project=chromium",
    "test:e2e:prod": "E2E_BASE_URL=https://app.shareshopi.workers.dev E2E_SKIP_WEB_SERVER=1 playwright test tests/e2e/production-smoke.spec.ts --project=chromium",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "firebase": "^12.15.0",
    "idb": "^8.0.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.8",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "wrangler": "^4.99.0"
  }
}
